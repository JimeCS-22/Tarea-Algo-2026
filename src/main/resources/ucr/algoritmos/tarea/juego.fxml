<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="controller.GameController"
           style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298);">

    <VBox alignment="CENTER" spacing="20">

        <!-- Título -->
        <Label text="🎮 Adivina el Personaje"
               style="-fx-font-size: 26px; -fx-text-fill: white; -fx-font-weight: bold;" />

        <!-- Tarjeta del juego -->
        <VBox spacing="15" alignment="CENTER"
              style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10,0,0,4);"
              maxWidth="350">

            <!-- Selector de dificultad -->
            <HBox spacing="10" alignment="CENTER">
                <Label text="Dificultad:" style="-fx-font-weight: bold;"/>
                <Button text="Fácil"
                        onAction="#handleFacil"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 10;"
                        styleClass="btn-facil"/>

                <Button text="Dificil"
                        onAction="#handleDificil"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 10;"
                        styleClass="btn-dificil"/>
            </HBox>

            <!-- Pista -->
            <Label fx:id="lblPista"
                   text="Aquí aparecerá la pista..."
                   wrapText="true"
                   style="-fx-font-size: 15px; -fx-text-fill: #333;"
                   maxWidth="250" />

            <!-- Campo -->
            <TextField fx:id="txtRespuesta"
                       promptText="Escribe tu respuesta..."
                       maxWidth="200"
                       style="-fx-background-radius: 10;" />

            <!-- Botón adivinar -->
            <Button text="Adivinar"
                    onAction="#handleAdivinar"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 10;"
                    styleClass="btn-adivinar"/>

            <!-- Resultado -->
            <Label fx:id="lblResultado"
                   text=""
                   style="-fx-font-size: 14px; -fx-font-weight: bold;" />

            <!-- Info -->
            <HBox spacing="20" alignment="CENTER">
                <Label fx:id="lblVidas"
                       text="❤️ Vidas: 3"
                       style="-fx-text-fill: #e53935; -fx-font-weight: bold;"/>

                <Label fx:id="lblPuntaje"
                       text="⭐ Puntaje: 0"
                       style="-fx-text-fill: #ff9800; -fx-font-weight: bold;"/>
            </HBox>

        </VBox>

    </VBox>

</StackPane>